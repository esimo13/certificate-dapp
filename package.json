{
  "name": "certificate-verification-dapp",
  "version": "1.0.0",
  "description": "Decentralized certificate verification system using blockchain",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=@certificate-dapp/frontend",
    "build": "npm run build --workspaces",
    "start:frontend": "npm run dev --workspace=@certificate-dapp/frontend",
    "start:backend": "npm run dev --workspace=certificate-backend",
    "deploy:contracts": "npm run deploy --workspace=@certificate-dapp/contracts",
    "blockchain": "npm run node --workspace=@certificate-dapp/contracts",
    "setup": "npm install"
  },
  "keywords": [
    "blockchain",
    "certificate",
    "verification",
    "ethereum",
    "nextjs",
    "dapp"
  ],
  "author": "Certificate DApp Team",
  "license": "MIT",
  "devDependencies": {
    "typescript": "^5.6.3"
  }
}
